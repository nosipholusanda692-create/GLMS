@model Contract
@{ ViewData["Title"] = "Delete Contract"; }

<h2>Delete Contract</h2>
<div class="alert alert-danger">Are you sure you want to delete <strong>@Model.Title</strong>?</div>

<dl class="row">
    <dt class="col-sm-3">Client</dt><dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
