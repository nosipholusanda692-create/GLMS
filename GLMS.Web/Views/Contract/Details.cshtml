@model Contract
@{ ViewData["Title"] = "Contract Details"; }

<div class="d-flex justify-content-between align-items-start mb-3">
    <h2>@Model.Title</h2>
    <span class="badge fs-6 bg-@(Model.Status == ContractStatus.Active ? "success" :
                                  Model.Status == ContractStatus.Expired ? "danger" :
                                  Model.Status == ContractStatus.OnHold ? "warning" : "secondary")">
        @Model.Status
    </span>
</div>
<hr />

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>
    <dt class="col-sm-3">Signed Agreement</dt>
    <dd class="col-sm-9">
        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
        {
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Download PDF</a>
        }
        else
        {
            <span class="text-muted">Not uploaded</span>
        }
    </dd>
</dl>

<h4 class="mt-4">Service Requests</h4>
@if (Model.ServiceRequests.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-secondary">
            <tr><th>Description</th><th>Cost (USD)</th><th>Cost (ZAR)</th><th>Status</th><th>Date</th></tr>
        </thead>
        <tbody>
            @foreach (var sr in Model.ServiceRequests)
            {
                <tr>
                    <td>@sr.Description</td>
                    <td>$@sr.CostUSD.ToString("F2")</td>
                    <td>R @sr.CostZAR.ToString("F2")</td>
                    <td>@sr.Status</td>
                    <td>@sr.CreatedDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No service requests for this contract.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
