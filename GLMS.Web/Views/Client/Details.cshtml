@model Client
@{ ViewData["Title"] = "Client Details"; }

<h2>@Model.Name</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Contact Details</dt>
    <dd class="col-sm-9">@Model.ContactDetails</dd>
    <dt class="col-sm-3">Region</dt>
    <dd class="col-sm-9">@Model.Region</dd>
</dl>

<h4>Contracts</h4>
@if (Model.Contracts.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-secondary">
            <tr><th>Title</th><th>Status</th><th>Start</th><th>End</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Contracts)
            {
                <tr>
                    <td>@c.Title</td>
                    <td><span class="badge bg-@(c.Status == ContractStatus.Active ? "success" : c.Status == ContractStatus.Expired ? "danger" : "secondary")">@c.Status</span></td>
                    <td>@c.StartDate.ToShortDateString()</td>
                    <td>@c.EndDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No contracts yet.</p>
}

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
