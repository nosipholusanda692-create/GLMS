@model List<ServiceRequest>
@{ ViewData["Title"] = "Service Requests"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Service Requests</h2>
    <a asp-action="Create" class="btn btn-success">+ New Request</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Description</th>
            <th>Contract</th>
            <th>Client</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var req in Model)
        {
            <tr>
                <td>@req.Description</td>
                <td>@req.Contract?.Title</td>
                <td>@req.Contract?.Client?.Name</td>
                <td>$@req.CostUSD.ToString("F2")</td>
                <td>R @req.CostZAR.ToString("F2")</td>
                <td>@req.Status</td>
                <td>@req.CreatedDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@req.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted text-center">No service requests yet.</p>
}
